{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "FlowDan",
  "version": "2.0.0",
  "identifier": "com.flowdan.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "dashboard",
        "title": "FlowDan",
        "url": "/index.html",
        "width": 960,
        "height": 660,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "shadow": false,
        "center": true,
        "visible": false,
        "resizable": true,
        "transparent": false
      },
      {
        "label": "overlay",
        "title": "FlowDan Overlay",
        "url": "/overlay.html",
        "width": 240,
        "height": 52,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "ai-overlay",
        "title": "FlowDan AI",
        "url": "/ai-overlay.html",
        "width": 480,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "x": 720,
        "y": 40
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "FlowDan - Voice Dictation"
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://api.fontshare.com; font-src 'self' https://fonts.gstatic.com https://cdn.fontshare.com; connect-src 'self' https://api.openai.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}